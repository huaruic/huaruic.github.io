---
const { headings } = Astro.props;
const minDepth = Math.min(...headings.map((h: { depth: number }) => h.depth));
---

<nav
  class="fixed top-32 left-4 z-30 hidden max-h-[calc(100vh-12rem)] w-40 overflow-y-auto text-xs lg:block xl:left-[calc(50vw-36rem)] xl:w-56 xl:text-sm"
  aria-label="目录"
  data-pagefind-ignore
>
  <div
    class="mb-3 font-mono text-[0.6875rem] tracking-[0.16em] text-black/40 dark:text-white/40"
  >
    目录
  </div>
  <ul class="space-y-2">
    {
      headings.map((heading: { depth: number; slug: string; text: string }) => (
        <li style={`padding-left: ${(heading.depth - minDepth) * 0.75}rem`}>
          <a
            href={`#${heading.slug}`}
            class="text-black/50 transition-colors hover:text-black dark:text-white/50 dark:hover:text-white"
          >
            {heading.text}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
