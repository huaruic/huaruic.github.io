---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS, AUTHOR } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";
import { dateRange } from "@lib/utils";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter(
    project => !project.data.draft && typeof project.data.featured === "number"
  )
  .sort(
    (a, b) =>
      (a.data.featured ?? Number.POSITIVE_INFINITY) -
      (b.data.featured ?? Number.POSITIVE_INFINITY)
  )
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const work = (await getCollection("work"))
  .sort((a, b) => b.data.dateStart.valueOf() - a.data.dateStart.valueOf())
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const personId = `${AUTHOR.URL}/#person`;
const websiteId = `${AUTHOR.URL}/#website`;
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": personId,
      name: AUTHOR.NAME,
      alternateName: AUTHOR.ALIAS,
      url: `${AUTHOR.URL}/`,
      image: `${AUTHOR.URL}${AUTHOR.AVATAR}`,
      email: `mailto:${AUTHOR.EMAIL}`,
      sameAs: [AUTHOR.X, AUTHOR.GITHUB],
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      name: SITE.TITLE,
      url: `${AUTHOR.URL}/`,
      publisher: { "@id": personId },
      inLanguage: "zh-CN",
    },
    {
      "@type": "ProfilePage",
      "@id": `${AUTHOR.URL}/#profilepage`,
      url: `${AUTHOR.URL}/`,
      mainEntity: { "@id": personId },
      isPartOf: { "@id": websiteId },
    },
  ],
});
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <script is:inline type="application/ld+json" set:html={jsonLd} />
  <Container>
    <div data-pagefind-ignore>
      <div class="space-y-16">
        <section class="space-y-6">
          {/* 文案为待所有者确认的草稿（tasks 7.1 / 1.3） */}
          <h1
            class="text-3xl font-semibold tracking-tight text-black sm:text-4xl dark:text-white"
          >
            Hey 👋，我是 Ernest
          </h1>
          <p
            class="text-lg font-medium text-black/90 sm:text-xl dark:text-white/90"
          >
            把 AI Agent 从 Demo 变成普通人每天用得上的产品。
          </p>
          <p class="max-w-[60ch] leading-7 text-pretty">
            专注本地优先与隐私优先的智能体：目前主要在做
            <Link href="/projects/catclaw/">CatClaw</Link>（本地 AI Agent
            桌面应用）和
            <Link href="/projects/clawsetup/">ClawSetup</Link>（让 macOS
            用户不用终端也能安装配置
            OpenClaw）。这里也记录我的工程实践、工作复盘与生活。
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/projects/"
              class="rounded-md bg-black px-5 py-2.5 text-sm font-medium text-white transition-colors duration-300 ease-in-out hover:bg-black/80 focus-visible:bg-black/80 dark:bg-white dark:text-black dark:hover:bg-white/85 dark:focus-visible:bg-white/85"
            >
              查看代表项目
            </a>
            <a
              href={`mailto:${AUTHOR.EMAIL}`}
              class="rounded-md border border-black/15 px-5 py-2.5 text-sm font-medium transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
            >
              联系我
            </a>
          </div>
        </section>

        <section class="space-y-6">
          <div class="flex flex-wrap items-center justify-between gap-y-2">
            <h2 class="font-semibold text-black dark:text-white">近期项目</h2>
            <Link href="/projects/">查看全部项目</Link>
          </div>
          <ul class="not-prose flex flex-col gap-4">
            {
              projects.map(project => (
                <li>
                  <ArrowCard entry={project} />
                </li>
              ))
            }
          </ul>
        </section>

        <section class="space-y-6">
          <div class="flex flex-wrap items-center justify-between gap-y-2">
            <h2 class="font-semibold text-black dark:text-white">工作经历</h2>
            <Link href="/work/">查看全部经历</Link>
          </div>
          <ol class="not-prose flex flex-col gap-7">
            {
              work.map(entry => (
                <li class="space-y-2">
                  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                    <div class="font-semibold text-black dark:text-white">
                      {entry.data.company}
                    </div>
                    <div class="font-mono text-xs tabular-nums opacity-80">
                      {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                    </div>
                  </div>
                  <div class="text-sm opacity-75">
                    {entry.data.role}
                    {entry.data.location && ` · ${entry.data.location}`}
                  </div>
                  <p class="text-sm leading-6 text-pretty">
                    {entry.data.summary}
                  </p>
                </li>
              ))
            }
          </ol>
        </section>

        <section class="space-y-6">
          <div class="flex flex-wrap items-center justify-between gap-y-2">
            <h2 class="font-semibold text-black dark:text-white">最新文章</h2>
            <Link href="/blog/">查看全部文章</Link>
          </div>
          <ul class="not-prose flex flex-col gap-4">
            {
              blog.map(post => (
                <li>
                  <ArrowCard entry={post} />
                </li>
              ))
            }
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="font-semibold text-black dark:text-white">联系我</h2>
          <p class="max-w-[60ch] leading-7 text-pretty">
            如果你也在构建 AI Agent、本地优先应用或 AI-native
            开发工作流，或者只是想打个招呼，欢迎通过社交媒体或邮件联系我。
          </p>
          <ul class="not-prose flex flex-wrap gap-2">
            {
              SOCIALS.map(SOCIAL => (
                <li class="flex gap-x-2 text-nowrap">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    aria-label={`${AUTHOR.ALIAS} 的 ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </Link>
                  {"/"}
                </li>
              ))
            }
            <li class="line-clamp-1">
              <Link
                href={`mailto:${AUTHOR.EMAIL}`}
                aria-label={`发邮件给 ${AUTHOR.ALIAS}：${AUTHOR.EMAIL}`}
              >
                {AUTHOR.EMAIL}
              </Link>
            </li>
          </ul>
        </section>
      </div>
    </div>
  </Container>
</Layout>
