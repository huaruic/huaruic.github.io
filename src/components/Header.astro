---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";

const path = Astro.url.pathname;

const navItems = [
  { href: "/blog/", label: "博客" },
  { href: "/work/", label: "经历" },
  { href: "/projects/", label: "项目" },
];

const isActive = (href: string) => path === href || path.startsWith(href);
---

<header transition:persist>
  <Container>
    <div class="flex flex-wrap justify-between gap-y-2">
      <Link href="/" underline={false} aria-label={SITE.TITLE}>
        <div class="flex min-h-11 items-center gap-2 font-semibold">
          <img
            src="/ernest-avatar-96.png"
            alt=""
            width="24"
            height="24"
            class="size-6 rounded-md object-cover ring-1 ring-black/10 dark:ring-white/15"
          />
          <span class="hidden sm:inline" aria-hidden="true">
            {SITE.TITLE}
          </span>
        </div>
      </Link>
      <nav class="flex items-center gap-1 text-sm">
        {
          navItems.map((item, index) => (
            <>
              {index > 0 && <span aria-hidden="true">{`/`}</span>}
              <Link
                href={item.href}
                class={
                  isActive(item.href)
                    ? "flex min-h-11 items-center px-1 font-medium text-black dark:text-white"
                    : "flex min-h-11 items-center px-1"
                }
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </Link>
            </>
          ))
        }
        <span aria-hidden="true">
          {`/`}
        </span>
        <button
          id="magnifying-glass"
          aria-label="搜索（快捷键 Command K）"
          class="group flex min-h-11 items-center gap-1.5 px-1 transition-colors duration-300 ease-in-out hover:text-black focus-visible:text-black dark:hover:text-white dark:focus-visible:text-white"
        >
          <span
            class="underline decoration-black/30 underline-offset-[3px] group-hover:decoration-black/50 dark:decoration-white/30 dark:group-hover:decoration-white/50"
          >
            搜索
          </span>
          <kbd
            aria-hidden="true"
            class="hidden rounded-md border border-black/15 px-1.5 py-px font-sans text-[0.6875rem] text-black/45 sm:inline dark:border-white/20 dark:text-white/45"
            >⌘K</kbd
          >
        </button>
      </nav>
    </div>
  </Container>
</header>

<script is:inline>
  // header 使用 transition:persist，客户端导航后由 SSR 输出的 aria-current 会过期，这里同步
  document.addEventListener("astro:after-swap", () => {
    document.querySelectorAll("header nav a[href]").forEach(a => {
      const href = a.getAttribute("href");
      if (!href || href === "/") return;
      const active = location.pathname.startsWith(href.replace(/\/$/, ""));
      a.classList.toggle("font-medium", active);
      a.classList.toggle("text-black", active);
      a.classList.toggle("dark:text-white", active);
      if (active) {
        a.setAttribute("aria-current", "page");
      } else {
        a.removeAttribute("aria-current");
      }
    });
  });
</script>
