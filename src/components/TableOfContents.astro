---
import TableOfContentsHeading from "./TableOfContentsHeading.astro";

// https://kld.dev/building-table-of-contents/
const { headings } = Astro.props;
const toc = buildToc(headings);

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

function buildToc(headings: Heading[]) {
  const toc: Heading[] = [];
  const parentHeadings = new Map();
  headings.forEach(h => {
    const heading = { ...h, subheadings: [] };
    parentHeadings.set(heading.depth, heading);
    // 找最近的上级标题；文章里存在跳级标题（如无 h2 直接 h3）时回退到根
    let parent;
    for (let d = heading.depth - 1; d >= 1 && !parent; d--) {
      parent = parentHeadings.get(d);
    }
    if (parent) {
      parent.subheadings.push(heading);
    } else {
      toc.push(heading);
    }
  });
  return toc;
}
---

<details class="animate group fixed top-20 left-3 z-40 lg:hidden">
  <summary
    class="w-fit cursor-pointer list-none rounded-md border border-black/15 bg-neutral-100/90 px-3 py-1.5 text-sm font-medium shadow-sm backdrop-blur-md transition-colors hover:bg-neutral-200/90 dark:border-white/20 dark:bg-neutral-900/90 dark:hover:bg-neutral-800/90"
    >目录</summary
  >
  <nav
    class="mt-2 max-h-[calc(100dvh-9rem)] w-72 max-w-[calc(100vw-1.5rem)] overflow-y-auto rounded-lg border border-black/15 bg-neutral-100/95 shadow-lg backdrop-blur-md dark:border-white/20 dark:bg-neutral-900/95"
    onclick="this.closest('details')?.removeAttribute('open')"
  >
    <ul class="py-3">
      {toc.map(heading => <TableOfContentsHeading heading={heading} />)}
    </ul>
  </nav>
</details>
