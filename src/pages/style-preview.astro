---
import { Code } from "astro:components";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const previewCode = `type ThemeTokens = {
  background: string;
  text: string;
  accent: string;
};

const theme: ThemeTokens = {
  background: "#F6F1E8",
  text: "#4A4038",
  accent: "#8B6246",
};

export function getReadingTone(mode: "light" | "dark") {
  return mode === "light" ? theme.accent : "#D8C3A5";
}`;
---

<Layout title="暖色阅读风格预览 | Always Exploring" description="用于预览个人博客的暖色系阅读型配色与排版方案。">
  <div class="scheme-preview">
    <Header />

    <main id="main-content" class="app-layout preview-main">
      <section class="hero">
        <p class="eyebrow">Warm Editorial Reading Theme</p>
        <h1>暖色系阅读型博客预览</h1>
        <p class="lede">
          这是一页临时样式预览，用来验证米白、燕麦、焦糖、陶土这组低饱和暖色是否适合长文阅读。
          目标不是产品化界面，而是像一本安静展开的纸页式博客。
        </p>
        <div class="actions">
          <a class="button primary" href="/posts/">进入文章列表</a>
          <a class="button secondary" href="/tags/">查看标签</a>
        </div>
      </section>

      <section class="panel">
        <div class="section-head">
          <h2>导航与辅助信息</h2>
          <span class="meta">适合低对比、低噪音的站点头部</span>
        </div>
        <div class="nav-preview">
          <a href="#" class="active">首页</a>
          <a href="#">文章</a>
          <a href="#">标签</a>
          <a href="#">归档</a>
          <a href="#">关于</a>
        </div>
        <p class="supporting">
          导航建议使用较小字号和暖灰色，不依靠重背景条或高亮块，只用细下划线、颜色变化或少量留白来表达层级。
        </p>
      </section>

      <section class="section-grid">
        <article class="panel featured">
          <div class="section-head">
            <h2>置顶文章</h2>
            <span class="badge">Featured</span>
          </div>
          <h3>在缓慢中形成自己的节奏</h3>
          <p class="meta">2026-03-23 · 阅读、工作、生活</p>
          <p>
            置顶文章不需要夸张高亮。更适合用更浅的燕麦底、细陶土边线，和稍微放大的标题去建立“这篇值得先读”的暗示。
          </p>
          <div class="tag-row">
            <span class="tag">年终总结</span>
            <span class="tag">生活</span>
            <span class="tag">写作</span>
          </div>
        </article>

        <article class="panel list">
          <div class="section-head">
            <h2>文章列表</h2>
            <span class="meta">列表卡片示意</span>
          </div>
          <ul class="post-list">
            <li>
              <a href="#">为什么持续写作仍然重要</a>
              <span>用柔和标题和较松的摘要节奏，替代传统博客中偏硬的列表排列。</span>
            </li>
            <li>
              <a href="#">关于工作、表达和时间感的一些记录</a>
              <span>日期、分类、摘要建议使用辅助文字，不与标题争抢注意力。</span>
            </li>
            <li>
              <a href="#">在旅行中重新理解秩序与自由</a>
              <span>卡片用轻边框和少量背景层次即可，不需要厚重阴影。</span>
            </li>
          </ul>
        </article>
      </section>

      <section class="reading-demo">
        <article class="article">
          <div class="section-head">
            <h2>正文阅读区</h2>
            <span class="meta">长文排版预览</span>
          </div>

          <p>
            合适的阅读主题不只是颜色温暖，更重要的是让标题、段落、链接、引文、代码块之间形成稳定秩序。页面应当像纸张一样安静，不急着向读者推销交互，而是愿意让文字自己工作。
          </p>

          <p>
            这套方案里，正文主色偏暖棕灰，避免纯黑带来的压迫感；链接使用焦糖棕，不做科技蓝；背景是奶油和燕麦之间的中间值，使页面在白天光线下仍然柔和。
          </p>

          <blockquote>
            一页适合阅读的界面，首先应该安静。颜色的任务不是吸引注意，而是保护注意。
          </blockquote>

          <p>
            如果需要在正文里放置
            <a href="#">链接示例</a>
            ，建议只让它比正文略暖、略深，并在 hover 时变化一点点就够了，不要破坏整页气氛。
          </p>

          <Code
            code={previewCode}
            lang="ts"
            themes={{ light: "gruvbox-light-soft", dark: "gruvbox-dark-soft" }}
            defaultColor={false}
          />
        </article>

        <aside class="panel side-notes">
          <div class="section-head">
            <h2>标签与引用</h2>
            <span class="meta">组件预览</span>
          </div>
          <div class="tag-row">
            <span class="tag">周记</span>
            <span class="tag">旅行</span>
            <span class="tag">工作</span>
            <span class="tag">书籍</span>
          </div>
          <p class="supporting">
            标签更适合像纸质索引签，而不是高饱和 UI 徽章。圆角可以保留，但不要过于产品化。
          </p>
          <div class="divider"></div>
          <p class="footer-note">
            页脚、日期、说明文案建议统一落在更浅一层的暖灰色上，形成稳定的阅读尾音。
          </p>
        </aside>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .scheme-preview {
    --background: #F6F1E8;
    --foreground: #4A4038;
    --accent: #8B6246;
    --muted: #E8DFD1;
    --border: #D9CCBC;

    --preview-bg-soft: #EFE7DA;
    --preview-surface: #FBF7F0;
    --preview-surface-hover: #F7F1E7;
    --preview-title: #3A312B;
    --preview-text-soft: #7A6C5F;
    --preview-text-faint: #9A8B7C;
    --preview-nav: #5A4D43;
    --preview-nav-active: #7B5C46;
    --preview-link-hover: #A07052;
    --preview-button: #B79272;
    --preview-button-hover: #A98263;
    --preview-button-text: #FFF9F2;
    --preview-button-secondary: #E8DDD0;
    --preview-button-secondary-hover: #DDD0C1;
    --preview-button-secondary-text: #5B4A3D;
    --preview-tag-bg: #E9DED1;
    --preview-tag-text: #6B5647;
    --preview-tag-hover: #DDCDBD;
    --preview-quote-bg: #F2EADF;
    --preview-quote-border: #C9AE93;
    --preview-code-bg: #EDE4D7;
    --preview-code-border: #D6C7B6;

    --font-heading: "Cormorant Garamond", "LXGW WenKai TC", "STKaiti", "KaiTi", serif;
    --font-body: "Source Serif 4", "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
    --font-ui: "Noto Sans SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    --font-mono: "Iosevka", "JetBrains Mono", "IBM Plex Mono", "SFMono-Regular", monospace;

    background: var(--background);
    color: var(--foreground);
    font-family: var(--font-body);
  }

  .scheme-preview :global(a) {
    color: var(--accent);
  }

  .scheme-preview :global(a:hover) {
    color: var(--preview-link-hover);
  }

  .preview-main {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .hero,
  .panel,
  .article {
    border: 1px solid var(--border);
    background: var(--preview-surface);
  }

  .hero {
    padding: 2rem;
    border-radius: 20px;
  }

  .hero h1,
  .section-head h2,
  .featured h3 {
    margin: 0;
    color: var(--preview-title);
    font-family: var(--font-heading);
  }

  .hero h1 {
    margin-top: 0.4rem;
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    line-height: 1.16;
    letter-spacing: 0.01em;
  }

  .eyebrow,
  .meta,
  .supporting,
  .footer-note {
    color: var(--preview-text-soft);
    font-family: var(--font-ui);
  }

  .eyebrow {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lede {
    max-width: 46rem;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.95;
  }

  .actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.78rem 1.15rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease;
  }

  .button.primary {
    background: var(--preview-button);
    color: var(--preview-button-text);
  }

  .button.primary:hover {
    background: var(--preview-button-hover);
    color: var(--preview-button-text);
  }

  .button.secondary {
    background: var(--preview-button-secondary);
    border-color: var(--border);
    color: var(--preview-button-secondary-text);
  }

  .button.secondary:hover {
    background: var(--preview-button-secondary-hover);
    color: var(--preview-button-secondary-text);
  }

  .panel,
  .article {
    padding: 1.35rem 1.4rem;
    border-radius: 18px;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-head h2 {
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .nav-preview {
    display: flex;
    gap: 1.15rem;
    flex-wrap: wrap;
    margin-bottom: 0.9rem;
    font-family: var(--font-ui);
    font-size: 0.94rem;
  }

  .nav-preview a {
    color: var(--preview-nav);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 0.2rem;
  }

  .nav-preview a.active,
  .nav-preview a:hover {
    color: var(--preview-nav-active);
    border-color: var(--preview-nav-active);
  }

  .section-grid,
  .reading-demo {
    display: grid;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .section-grid {
    grid-template-columns: 1.05fr 0.95fr;
  }

  .reading-demo {
    grid-template-columns: minmax(0, 1.25fr) minmax(260px, 0.75fr);
  }

  .featured {
    background: linear-gradient(180deg, var(--preview-surface) 0%, var(--preview-surface-hover) 100%);
    box-shadow: inset 3px 0 0 var(--preview-quote-border);
  }

  .featured h3 {
    margin-top: 0.35rem;
    font-size: 2rem;
    line-height: 1.2;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    background: var(--preview-tag-bg);
    color: var(--preview-tag-text);
    padding: 0.32rem 0.72rem;
    font-family: var(--font-ui);
    font-size: 0.78rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list li + li {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .post-list a {
    display: block;
    color: var(--preview-title);
    font-family: var(--font-heading);
    font-size: 1.45rem;
    line-height: 1.25;
    text-decoration: none;
    margin-bottom: 0.35rem;
  }

  .post-list span {
    color: var(--preview-text-soft);
    line-height: 1.8;
  }

  .article {
    line-height: 1.95;
    font-size: 1.03rem;
  }

  .article p {
    margin: 0 0 1.15rem;
  }

  .article blockquote {
    margin: 1.5rem 0;
    padding: 1rem 1.1rem;
    border-left: 4px solid var(--preview-quote-border);
    background: var(--preview-quote-bg);
    color: var(--preview-title);
    font-size: 1.03rem;
  }

  .article :global(pre) {
    overflow-x: auto;
    margin: 1.5rem 0 0;
    padding: 1rem 1.1rem;
    border: 1px solid var(--preview-code-border);
    border-radius: 14px;
    background: var(--preview-code-bg);
  }

  .article :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--preview-title);
  }

  .article :global(.astro-code) {
    background: var(--preview-code-bg);
    border-color: var(--preview-code-border);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.35);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    background: var(--preview-tag-bg);
    color: var(--preview-tag-text);
    padding: 0.38rem 0.78rem;
    font-family: var(--font-ui);
    font-size: 0.84rem;
  }

  .tag:hover {
    background: var(--preview-tag-hover);
  }

  .divider {
    margin: 1rem 0;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .section-grid,
    .reading-demo {
      grid-template-columns: 1fr;
    }
  }
</style>
